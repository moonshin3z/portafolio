# ===========================================
# Variables para el FRONTEND (Vercel)
# ===========================================
# URL del API de contacto (solo si el backend está en otro dominio)
# Ejemplo: https://tu-api.railway.app
VITE_CONTACT_API_URL=

# ===========================================
# Variables para el BACKEND (Railway / Render)
# ===========================================
# Puerto (Railway/Render lo asignan automáticamente)
PORT=3001

# Origen permitido para CORS (URL de tu frontend en Vercel)
# Ejemplo: https://tu-portafolio.vercel.app
CORS_ORIGIN=

# Opcional: Configuración SMTP para enviar emails reales
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
